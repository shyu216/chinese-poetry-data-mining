// WordSimilarity.fbs
// FlatBuffers schema for word similarity data

namespace WordSimilarity;

table SimilarWord {
  word_id: int;
  similarity: int;  // similarity * 10000 as int
}

table WordEntry {
  word_id: int;           // 词在词表中的索引 ID (非词频!)
  frequency: int;        // FastText 内部索引 (非真实词频!)
  similar_words: [SimilarWord];
}

table WordSimilarityFile {
  words: [WordEntry];
  vocab: [string];  // word_id -> word
}

root_type WordSimilarityFile;
file_identifier "WRSV";
